# Normalize line endings for text sources.
* text=auto

# The official source workbooks (ONS .xlsx, HMRC .xls/.ods) are small (≤1 MB
# each) and committed directly as regular binary blobs — no Git LFS required.
*.xlsx binary
*.xls binary
*.ods binary

# The generated synthetic firm population (data/synthetic/*.csv) is large and is
# NOT committed at all — it is regenerated by the firm_microsim package and is
# excluded via .gitignore.
